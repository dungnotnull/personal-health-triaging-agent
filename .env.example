# ── Environment Variables — PHTA ────────────────────────────────────
# Copy to .env and fill in your values.

# ── LLM Provider ──────────────────────────────────────────────────
# Options: "anthropic" (online), "ollama" (offline)
LLM_PROVIDER=ollama
ANTHROPIC_API_KEY=
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ── Speech-to-Text / Text-to-Speech ────────────────────────────────
WHISPER_MODEL=large-v3
TTS_PROVIDER=edge_tts
TTS_VOICE_VI=vi-VN-HoaiMyNeural
TTS_VOICE_EN=en-US-AriaNeural

# ── Wearable APIs ──────────────────────────────────────────────────
APPLE_HEALTH_ENABLED=false
GOOGLE_HEALTH_CLIENT_ID=
FITBIT_CLIENT_ID=
FITBIT_CLIENT_SECRET=
GARMIN_CLIENT_ID=

# ── Storage ────────────────────────────────────────────────────────
HEALTH_DB_PATH=~/.phta/health.db
HEALTH_DB_ENCRYPTION_KEY=
SESSION_TTL_HOURS=24

# ── Knowledge Crawler ──────────────────────────────────────────────
PUBMED_API_KEY=
KNOWLEDGE_CRAWL_SCHEDULE="0 2 * * 0"

# ── Emergency Contacts (localized) ──────────────────────────────────
EMERGENCY_NUMBER_PRIMARY=115
EMERGENCY_NUMBER_SECONDARY=1800599920
